{
  "name": "react-debug-mcp",
  "version": "1.0.0",
  "description": "MCP server with high-level React-specific debugging tools for AI agents.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "react-debug-mcp": "src/index.ts"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import tsx src/index.ts",
    "start:debug": "node --env-file-if-exists=.env --inspect=9229 --import tsx src/index.ts",
    "start:inspect": "npx @modelcontextprotocol/inspector node --env-file-if-exists=.env --import tsx src/index.ts",
    "start:inspect:debug": "npx @modelcontextprotocol/inspector node --env-file-if-exists=.env --inspect=9229 --import tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chrome-remote-interface": "^0.33.2",
    "source-map-js": "^1.2.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "*",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "resolutions": {
    "commander": "^13.0.0"
  },
  "keywords": [
    "mcp",
    "react",
    "debugging",
    "chrome-devtools",
    "cdp"
  ],
  "license": "MIT"
}
