# react-debug-mcp — environment configuration
#
# Copy this file to `.env` and adjust. The `start*` scripts in package.json load
# it automatically via `node --env-file-if-exists=.env`, so editing `.env`
# updates the config for all four run modes at once.
#
# Precedence: a variable already set in your shell/CI environment WINS over the
# value here (Node does not override existing process env). `.env` is gitignored;
# this `.env.example` is the committed template. All keys are parsed once in
# src/env.ts.

# ── Chrome DevTools Protocol ────────────────────────────────────────────────
# Host of Chrome's remote-debugging endpoint. Prefer 127.0.0.1 over "localhost":
# Chrome's debug port binds to IPv4 only, but "localhost" often resolves to IPv6
# (::1) first (e.g. Windows + Node 18+), which fails with ECONNREFUSED.
CDP_HOST=127.0.0.1
# Port passed to Chrome's --remote-debugging-port.
CDP_PORT=9222
# Optional: URL substring selecting which tab to attach to.
# Leave empty to use the first real page tab.
CDP_TARGET_URL=

# ── Logging ─────────────────────────────────────────────────────────────────
# stderr verbosity: debug | info | warn | error
LOG_LEVEL=info
# Optional: also append logs to this file. Empty = stderr only.
LOG_FILE=
